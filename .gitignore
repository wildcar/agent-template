# Local agent / IDE state — do not commit.
# Exceptions: shared team settings and project skills travel with the repo.
# Personal overrides stay in .claude/settings.local.json (ignored).
.claude/*
!.claude/settings.json
!.claude/skills/

# Environment / secrets
.env
.env.local
.env*.local

# OS / editor noise
.DS_Store
Thumbs.db
*.swp

